# ============================================
# VINTEL - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
PORT=3000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/vintel?retryWrites=true&w=majority

# OpenAI API (for GPT-4 Risk Classification)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── WhatsApp Business API ─────────────────────────────────────
# HIGH RISK → Immediate alert to DSP_RECIPIENTS
# MEDIUM RISK → Dashboard only (no WhatsApp)
# LOW RISK → Log only

WHATSAPP_API_URL=https://graph.facebook.com/v18.0/<PHONE_NUMBER_ID>/messages
WHATSAPP_ACCESS_TOKEN=your_whatsapp_business_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# DSP Recipients — HIGH RISK alerts go here (comma-separated, with country code)
DSP_RECIPIENTS=+919876543210,+919876543211

# General Alert Recipients (fallback if DSP_RECIPIENTS not set)
ALERT_RECIPIENTS=+919876543212,+919876543213

# ─── Twitter/X API ─────────────────────────────────────────────
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ─── YouTube Data API v3 ───────────────────────────────────────
# Free tier: 10,000 units/day. One search = 100 units.
# Get key at: https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# ─── Scheduling ────────────────────────────────────────────────
# RSS + Twitter + YouTube poll interval (in minutes)
RSS_POLL_INTERVAL=5

# Classification Batch Size (GPT-4 parallel calls)
CLASSIFICATION_BATCH_SIZE=10

# ─── Dashboard Auth (optional) ─────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=vintel@2026
